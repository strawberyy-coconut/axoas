    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug executable 'todo-api'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=todo-api",
                    "--package=todo-api"
                ]
            },
            "args": []
        },
        {
            "name": "Debug unit tests in executable 'todo-api'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=todo-api",
                    "--package=todo-api"
                ]
            }
        },
        {
            "name": "Debug unit tests in library 'axoas'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--package=axoas"
                ]
            }
        },
        {
            "name": "Debug integration test 'integration'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--test=integration",
                    "--package=axoas"
                ]
            }
        },
        {
            "name": "Debug integration test 'openapi_tests'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--test=openapi_tests",
                    "--package=axoas"
                ]
            }
        }
    ]
}